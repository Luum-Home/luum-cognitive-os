# Lane-sharded test matrix (ADR-100 §CI distribution)
#
# Matrix is generated dynamically from .cognitive-os/test-lanes.yaml so adding
# a lane to the registry automatically adds it to CI — no workflow edits needed.
#
# Optional lanes (arena, benchmark, quality, e2e, smoke, integration, …) are
# excluded from the default matrix. Enable with workflow_dispatch + include-optional.

name: test-lanes

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:
    inputs:
      include-optional:
        description: "Include optional lanes (arena, benchmark, quality, e2e, smoke, integration, …)"
        required: false
        default: "false"
        type: boolean

concurrency:
  group: test-lanes-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ── Setup: parse .cognitive-os/test-lanes.yaml and emit matrix lists ─────────
  setup:
    name: Parse lane registry
    runs-on: ubuntu-latest
    outputs:
      parallel-lanes: ${{ steps.parse.outputs.parallel }}
      serial-lanes:   ${{ steps.parse.outputs.serial }}
      optional-lanes: ${{ steps.parse.outputs.optional }}
      release-blocking-lanes: ${{ steps.parse.outputs.release_blocking }}
      environmental-lanes: ${{ steps.parse.outputs.environmental }}
      cost-bearing-lanes: ${{ steps.parse.outputs.cost_bearing }}
    steps:
      - uses: actions/checkout@v4
      - id: parse
        name: Emit lane groups as JSON
        run: |
          python3 - <<'EOF' >> "$GITHUB_OUTPUT"
          import yaml, json

          with open('.cognitive-os/test-lanes.yaml') as f:
              data = yaml.safe_load(f)

          lanes = data.get('lanes', {})

          parallel = [
              name for name, cfg in lanes.items()
              if cfg.get('parallel') is True and not cfg.get('optional')
          ]
          serial = [
              name for name, cfg in lanes.items()
              if cfg.get('parallel') is False and not cfg.get('optional')
          ]
          optional = [
              name for name, cfg in lanes.items()
              if cfg.get('optional')
          ]
          release_blocking = [
              name for name, cfg in lanes.items()
              if cfg.get('gate_class') == 'release_blocking'
          ]
          environmental = [
              name for name, cfg in lanes.items()
              if cfg.get('gate_class') == 'environmental'
          ]
          cost_bearing = [
              name for name, cfg in lanes.items()
              if cfg.get('gate_class') == 'cost_bearing'
          ]

          print(f"parallel={json.dumps(parallel)}")
          print(f"serial={json.dumps(serial)}")
          print(f"optional={json.dumps(optional)}")
          print(f"release_blocking={json.dumps(release_blocking)}")
          print(f"environmental={json.dumps(environmental)}")
          print(f"cost_bearing={json.dumps(cost_bearing)}")
          EOF

  # ── Parallel-safe lanes ───────────────────────────────────────────────────────
  parallel-safe:
    name: lane (${{ matrix.lane }})
    needs: setup
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        lane: ${{ fromJson(needs.setup.outputs.parallel-lanes) }}
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.14"
          cache: pip
      - uses: actions/setup-go@v5
        with:
          go-version: "1.23"
          cache: true
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install uv
          uv pip install --system -e ".[testing]"
      - name: Build cos-test
        run: |
          cd cmd/cos-test && go build -o ../../cos-test .
      - name: Run lane
        env:
          CI: "true"
          COS_PYTEST_RERUNS: "1"
          COS_PYTEST_RERUNS_DELAY: "0"
        run: ./cos-test cluster --lane "${{ matrix.lane }}"
      - if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-run-${{ matrix.lane }}
          path: .cognitive-os/reports/test-runs/latest/
          retention-days: 7

  # ── Serial / stateful lanes ───────────────────────────────────────────────────
  serial-stateful:
    name: lane (${{ matrix.lane }})
    needs: setup
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        lane: ${{ fromJson(needs.setup.outputs.serial-lanes) }}
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.14"
          cache: pip
      - uses: actions/setup-go@v5
        with:
          go-version: "1.23"
          cache: true
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install uv
          uv pip install --system -e ".[testing]"
      - name: Build cos-test
        run: |
          cd cmd/cos-test && go build -o ../../cos-test .
      - name: Run lane
        env:
          CI: "true"
          COS_PYTEST_RERUNS: "1"
          COS_PYTEST_RERUNS_DELAY: "0"
        run: ./cos-test cluster --lane "${{ matrix.lane }}"
      - if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-run-${{ matrix.lane }}
          path: .cognitive-os/reports/test-runs/latest/
          retention-days: 7

  # ── Release-blocking semantic broad gate ─────────────────────────────────────
  release-blocking-broad:
    name: release-blocking broad summary
    needs: setup
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.14"
          cache: pip
      - uses: actions/setup-go@v5
        with:
          go-version-file: cmd/cos-test/go.mod
          cache: true
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install uv
          uv pip install --system -e ".[testing]"
      - name: Run hermetic broad dry-run contract
        run: |
          cd cmd/cos-test
          go run . broad --dry-run --no-docker --json

  # ── Environmental lanes (workflow_dispatch reporting only) ──────────────────
  environmental-lanes:
    name: environmental lane (${{ matrix.lane }})
    needs: setup
    if: github.event_name == 'workflow_dispatch' && inputs.include-optional == 'true'
    continue-on-error: true
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        lane: ${{ fromJson(needs.setup.outputs.environmental-lanes) }}
    timeout-minutes: 60
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.14"
          cache: pip
      - uses: actions/setup-go@v5
        with:
          go-version-file: cmd/cos-test/go.mod
          cache: true
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install uv
          uv pip install --system -e ".[testing]"
      - name: Build cos-test
        run: |
          cd cmd/cos-test && go build -o ../../cos-test .
      - name: Run environmental lane as drift radar
        env:
          CI: "true"
        run: ./cos-test cluster --lane "${{ matrix.lane }}"

  # ── Optional lanes (workflow_dispatch only) ───────────────────────────────────
  optional-lanes:
    name: optional lane (${{ matrix.lane }})
    needs: setup
    if: github.event_name == 'workflow_dispatch' && inputs.include-optional == 'true'
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        lane: ${{ fromJson(needs.setup.outputs.optional-lanes) }}
    timeout-minutes: 60
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.14"
          cache: pip
      - uses: actions/setup-go@v5
        with:
          go-version: "1.23"
          cache: true
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install uv
          uv pip install --system -e ".[testing]"
      - name: Build cos-test
        run: |
          cd cmd/cos-test && go build -o ../../cos-test .
      - name: Run optional lane
        env:
          CI: "true"
          COS_RUN_ARENA: "1"
          COS_RUN_BENCHMARK: "1"
          COS_RUN_QUALITY: "1"
        run: ./cos-test cluster --lane "${{ matrix.lane }}"
      - if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-run-${{ matrix.lane }}
          path: .cognitive-os/reports/test-runs/latest/
          retention-days: 7
