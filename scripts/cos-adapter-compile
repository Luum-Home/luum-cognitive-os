#!/usr/bin/env python3
# SCOPE: both
"""Compile COS primitive contracts into native consumer-project IDE files."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.adapter_compile import compile_adapter


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-dir", type=Path, default=Path.cwd(), help="Cognitive OS source/project root")
    parser.add_argument("harness")
    parser.add_argument("--output", type=Path, required=True, help="Consumer project directory to write/plan")
    parser.add_argument("--mode", choices=["default", "full"], default="default")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    receipt = compile_adapter(
        root=args.project_dir,
        harness=args.harness,
        output_dir=args.output,
        mode=args.mode,
        dry_run=args.dry_run,
    )
    if args.json:
        print(json.dumps(receipt, indent=2, sort_keys=True))
    else:
        print(f"adapter compile: {receipt['status']} harness={receipt['harness']} output={receipt['output_dir']}")
        print(f"proof={receipt['proof_level']} native_file_emission={receipt['native_file_emission']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
