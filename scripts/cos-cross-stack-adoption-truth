#!/usr/bin/env python3
"""CLI for ADR-217 cross-stack adoption-truth audit."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.cross_stack_adoption_truth import build_report, dumps_json  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Audit dependency adoption truth across lockfiles, NOTICE, docs, and inventories.")
    parser.add_argument("--project-dir", type=Path, default=ROOT)
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--strict", action="store_true")
    args = parser.parse_args()
    report = build_report(args.project_dir, strict=args.strict)
    if args.json:
        print(dumps_json(report))
    else:
        print(f"adoption truth audit: {report['status']} rows={report['summary']['rows']} findings={report['summary']['findings']}")
        for finding in report["findings"][:20]:
            print(f"[{finding['adoption_verdict']}] {finding['name']} lockfile={finding['in_lockfile']} notice={finding['in_notice']} status={finding['component_sources_status']}")
    return 1 if args.strict and report["summary"]["blocking_findings"] else 0


if __name__ == "__main__":
    raise SystemExit(main())
