#!/usr/bin/env python3
# SCOPE: os-only
"""CLI for ADR-215 cross-stack secret audit policy."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.cross_stack_secret_audit import audit, dumps_json, format_human, load_policy, write_latest_report  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Audit cross-stack secret scanner posture and sensitive local surfaces.")
    parser.add_argument("--project-dir", type=Path, default=ROOT)
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--strict", action="store_true", help="Exit non-zero on warn as well as block")
    parser.add_argument("--verify-live", action="store_true", help="Opt in to live verification warning; wrappers must still require explicit operator approval")
    parser.add_argument("--release-scope", action="store_true", help="Audit committed/release surfaces only; local secret-never-touch files remain covered by the default operator-safety mode")
    parser.add_argument("--no-write-latest", action="store_true", help="Do not update the latest redacted audit summary")
    args = parser.parse_args()

    report = audit(args.project_dir, verify_live=args.verify_live, include_local_sensitive_surfaces=not args.release_scope)
    if not args.no_write_latest:
        write_latest_report(args.project_dir.resolve(), report, load_policy(args.project_dir.resolve()))
    if args.json:
        print(dumps_json(report))
    else:
        print(format_human(report))
    if report["status"] == "block":
        return 2
    if args.strict and report["status"] == "warn":
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
