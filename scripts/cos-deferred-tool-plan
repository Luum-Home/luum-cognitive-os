#!/usr/bin/env python3
# SCOPE: os-only
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from lib.deferred_tool_loading import dumps_json, estimate_toolsearch_token_delta, list_changed, plan_tool_loading, provider_native_defer_payload, toolsearch_index  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Plan ADR-236 deferred tool loading.")
    parser.add_argument("--project-dir", default=".")
    parser.add_argument("--estimated-tool-tokens", type=int, default=0)
    parser.add_argument("--index", action="store_true")
    parser.add_argument("--list-changed", action="store_true")
    parser.add_argument("--update-state", action="store_true")
    parser.add_argument("--native-payload-provider")
    parser.add_argument("--token-delta", action="store_true", help="Emit local ToolSearch token-cost delta estimate")
    args = parser.parse_args()
    if args.index:
        print(dumps_json(toolsearch_index(args.project_dir)))
    elif args.token_delta:
        plan = plan_tool_loading(args.project_dir, estimated_tool_tokens=args.estimated_tool_tokens)
        print(dumps_json(plan.token_delta or estimate_toolsearch_token_delta(
            args.project_dir,
            estimated_tool_tokens=args.estimated_tool_tokens,
            toolsearch_enabled=plan.toolsearch_enabled,
            visible_tools=plan.visible_tools,
            deferred_tools=plan.deferred_tools,
        )))
    elif args.list_changed:
        print(dumps_json(list_changed(args.project_dir, update_state=args.update_state)))
    elif args.native_payload_provider:
        print(dumps_json(provider_native_defer_payload(args.project_dir, provider=args.native_payload_provider)))
    else:
        print(dumps_json(plan_tool_loading(args.project_dir, estimated_tool_tokens=args.estimated_tool_tokens)))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
