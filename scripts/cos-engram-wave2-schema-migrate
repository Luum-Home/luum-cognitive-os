#!/usr/bin/env python3
# SCOPE: os-only
"""Apply/check the additive Engram Wave 2 memory schema migration."""
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.engram_wave2_schema import ensure_wave2_schema


def default_db_path() -> Path:
    data_dir = Path(os.environ.get("ENGRAM_DATA_DIR", "~/.engram")).expanduser()
    return data_dir / "engram.db"


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--db", default=str(default_db_path()), help="Path to Engram SQLite DB")
    parser.add_argument("--check", action="store_true", help="Dry-run and report missing columns/indexes")
    parser.add_argument("--write", action="store_true", help="Apply additive migration")
    parser.add_argument("--json", action="store_true", help="Emit JSON")
    args = parser.parse_args()
    if not args.check and not args.write:
        parser.error("choose --check or --write")

    result = ensure_wave2_schema(args.db, dry_run=args.check)
    payload = result.to_dict()
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(
            "engram-wave2-schema: "
            f"{payload['status']} added_columns={len(payload['added_columns'])} "
            f"created_indexes={len(payload['created_indexes'])}"
        )
    return 0 if payload["status"] in {"pass", "would-change"} else 1


if __name__ == "__main__":
    raise SystemExit(main())
