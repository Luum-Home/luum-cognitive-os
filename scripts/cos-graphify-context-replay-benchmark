#!/usr/bin/env python3
# SCOPE: os-only
"""Replay Graphify context selection against real repository files.

This benchmark does not call a model. It builds two controlled prompt contexts
from real repo content: a broad baseline slice and the Graphify preload bundle.
It then writes paired Claude-style session JSONL fixtures with those measured
input-token counts and runs cos-graphify-run-telemetry to produce a comparable
before/after delta.
"""
from __future__ import annotations

import argparse
import json
import math
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable

ROOT = Path(__file__).resolve().parents[1]
PRELOAD_MATRIX = ROOT / "scripts" / "cos-graphify-preload-matrix"
JOINER = ROOT / "scripts" / "cos-graphify-run-telemetry"
DEFAULT_REPORT = ROOT / ".cognitive-os" / "reports" / "graphify-context-replay-benchmark.md"
DEFAULT_ARCHIVE = ROOT / ".cognitive-os" / "metrics" / "graphify-context-replay-benchmark.jsonl"
TEXT_SUFFIXES = {
    ".py", ".sh", ".bash", ".zsh", ".js", ".ts", ".tsx", ".jsx", ".go", ".rs", ".java", ".kt", ".rb", ".php", ".toml", ".json", ".yaml", ".yml", ".md",
}
BASELINE_ROOTS_BY_BUNDLE = {
    "harness-events": ("lib",),
    "history-rewrite": ("lib", "scripts"),
    "destructive-git": ("hooks",),
    "work-inventory": ("scripts", "hooks"),
    "agent-service-session": ("packages/agent-service",),
}
TASK = "Inspect the selected Cognitive OS primitive area and identify likely tests."
PREAMBLE = "You are a Cognitive OS maintainer. Use the provided context only."


def _run_matrix(items: list[str]) -> dict[str, Any]:
    completed = subprocess.run([str(PRELOAD_MATRIX), *items, "--json"], cwd=ROOT, check=False, capture_output=True, text=True)
    if completed.returncode != 0:
        raise SystemExit(completed.stderr.strip() or "preload matrix failed")
    return json.loads(completed.stdout)


def _bundle_keys(matrix: dict[str, Any]) -> list[str]:
    return [bundle["key"] for bundle in matrix.get("bundles", []) if isinstance(bundle, dict) and isinstance(bundle.get("key"), str)]


def _baseline_roots(bundle_keys: Iterable[str]) -> list[str]:
    roots: list[str] = []
    seen: set[str] = set()
    for key in bundle_keys:
        for root in BASELINE_ROOTS_BY_BUNDLE.get(key, ()):
            if root not in seen:
                seen.add(root)
                roots.append(root)
    return roots


def _is_text(path: Path) -> bool:
    if not path.is_file():
        return False
    rel_parts = path.relative_to(ROOT).parts
    blocked_parts = {
        "graphify-out",
        "__pycache__",
        ".pytest_cache",
        ".mypy_cache",
        ".ruff_cache",
        ".venv",
        "node_modules",
        "dist",
        "build",
    }
    if any(part in blocked_parts for part in rel_parts):
        return False
    if any(part.startswith(".") and part not in {".ai"} for part in rel_parts):
        return False
    return path.suffix in TEXT_SUFFIXES or path.name in {"Dockerfile", "Makefile"}


def _expand(paths: Iterable[str], *, max_files: int) -> list[Path]:
    files: list[Path] = []
    seen: set[Path] = set()
    for raw in paths:
        path = ROOT / raw
        if not path.exists():
            continue
        candidates = [path] if path.is_file() else sorted(candidate for candidate in path.rglob("*") if _is_text(candidate))
        for candidate in candidates:
            if candidate.is_file() and candidate not in seen and _is_text(candidate):
                seen.add(candidate)
                files.append(candidate)
                if len(files) >= max_files:
                    return files
    return files


def _count_tokens(text: str) -> int:
    try:
        import tiktoken  # type: ignore
    except Exception:
        return max(1, math.ceil(len(text) / 4))
    try:
        encoding = tiktoken.get_encoding("cl100k_base")
    except Exception:
        return max(1, math.ceil(len(text) / 4))
    return max(1, len(encoding.encode(text)))


def _context(files: list[Path]) -> tuple[str, dict[str, int]]:
    chunks: list[str] = []
    token_by_file: dict[str, int] = {}
    for path in files:
        rel = str(path.relative_to(ROOT))
        text = path.read_text(encoding="utf-8", errors="replace")
        chunk = f"\n--- FILE: {rel} ---\n{text}\n"
        chunks.append(chunk)
        token_by_file[rel] = _count_tokens(chunk)
    return "".join(chunks), token_by_file


def _write_session(path: Path, *, input_tokens: int, output_tokens: int, model: str) -> None:
    rows = [
        {
            "type": "assistant",
            "timestamp": "2026-05-22T10:00:00Z",
            "message": {
                "role": "assistant",
                "model": model,
                "usage": {
                    "input_tokens": input_tokens,
                    "output_tokens": output_tokens,
                    "cache_creation_input_tokens": 100,
                    "cache_read_input_tokens": 500,
                },
                "content": [
                    {"type": "tool_use", "id": "toolu_replay_read", "name": "Read", "input": {"file_path": "context-replay"}}
                ],
            },
        },
        {"type": "progress", "timestamp": "2026-05-22T10:02:00Z", "data": {"type": "agent_progress", "agentId": "agent-replay", "message": "done"}},
    ]
    path.write_text("\n".join(json.dumps(row) for row in rows) + "\n", encoding="utf-8")


def _run_joiner(*, baseline: Path, current: Path, matrix: Path) -> dict[str, Any]:
    completed = subprocess.run(
        [str(JOINER), "--session", str(current), "--baseline-session", str(baseline), "--matrix-json", str(matrix), "--json"],
        cwd=ROOT,
        check=False,
        capture_output=True,
        text=True,
    )
    if completed.returncode != 0:
        raise SystemExit(completed.stderr.strip() or completed.stdout.strip() or "run telemetry failed")
    return json.loads(completed.stdout)


def _render(summary: dict[str, Any]) -> str:
    return "\n".join([
        "# Graphify Context Replay Benchmark",
        "",
        "This benchmark simulates a controlled agent run using real repository file content. It measures prompt input tokens for a broad baseline context versus a Graphify preload context, then feeds those counts through `cos-graphify-run-telemetry`.",
        "",
        "## Result",
        "",
        f"Status: `{summary['status']}`",
        f"Estimator: `{summary['estimator']}`",
        f"Items: `{', '.join(summary['items'])}`",
        f"Bundles: `{', '.join(summary['bundle_keys'])}`",
        f"Baseline roots: `{', '.join(summary['baseline_roots'])}`",
        f"Baseline files: {summary['baseline_files']}",
        f"Preload files: {summary['preload_files']}",
        f"Baseline input tokens: {summary['baseline_input_tokens']}",
        f"Preload input tokens: {summary['preload_input_tokens']}",
        f"Output tokens held constant: {summary['output_tokens']}",
        f"Reduction: {summary['reduction_percent']}%",
        f"Saved input tokens: {summary['saved_input_tokens']}",
        "",
        "## Evidence vs Inference",
        "",
        "Evidence:",
        "",
        "- Baseline and preload contexts were assembled from real repository files.",
        "- The same task, preamble, model fixture, output tokens, cache values, and tool policy were held constant.",
        "- `cos-graphify-run-telemetry` computed the paired session delta from generated Claude-style JSONL fixtures.",
        "",
        "Inference boundary:",
        "",
        "- This is a controlled replay simulation, not live provider billing or production model behavior.",
        "",
    ])


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("items", nargs="+", help="Changed paths, symbols, or topic hints for preload matrix selection")
    parser.add_argument("--max-baseline-files", type=int, default=500, help="Safety cap for broad baseline files")
    parser.add_argument("--threshold-percent", type=float, default=20.0)
    parser.add_argument("--output-tokens", type=int, default=800)
    parser.add_argument("--model", default="claude-sonnet-replay")
    parser.add_argument("--archive", default=str(DEFAULT_ARCHIVE))
    parser.add_argument("--report", default=str(DEFAULT_REPORT))
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    matrix = _run_matrix(args.items)
    bundle_keys = _bundle_keys(matrix)
    baseline_roots = _baseline_roots(bundle_keys)
    baseline_files = _expand(baseline_roots, max_files=args.max_baseline_files)
    preload_files = _expand(matrix.get("preload_files", []), max_files=10_000)
    baseline_context, baseline_by_file = _context(baseline_files)
    preload_context, preload_by_file = _context(preload_files)
    baseline_input = _count_tokens(PREAMBLE + "\n" + TASK + "\n" + baseline_context)
    preload_input = _count_tokens(PREAMBLE + "\n" + TASK + "\n" + preload_context)

    with tempfile.TemporaryDirectory(prefix="cos-graphify-context-replay-") as raw_tmp:
        tmp = Path(raw_tmp)
        baseline_session = tmp / "baseline.jsonl"
        current_session = tmp / "graphify.jsonl"
        matrix_file = tmp / "matrix.json"
        matrix_file.write_text(json.dumps(matrix, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        _write_session(baseline_session, input_tokens=baseline_input, output_tokens=args.output_tokens, model=args.model)
        _write_session(current_session, input_tokens=preload_input, output_tokens=args.output_tokens, model=args.model)
        joined = _run_joiner(baseline=baseline_session, current=current_session, matrix=matrix_file)

    saved = baseline_input - preload_input
    reduction = round((saved / baseline_input) * 100, 2) if baseline_input else 0.0
    status = "pass" if saved > 0 and reduction >= args.threshold_percent else "fail"
    estimator = "tiktoken:cl100k_base" if "tiktoken" in sys.modules else "ceil(characters/4)"
    summary = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "status": status,
        "items": args.items,
        "bundle_keys": bundle_keys,
        "baseline_roots": baseline_roots,
        "baseline_files": len(baseline_files),
        "preload_files": len(preload_files),
        "baseline_input_tokens": baseline_input,
        "preload_input_tokens": preload_input,
        "output_tokens": args.output_tokens,
        "saved_input_tokens": saved,
        "reduction_percent": reduction,
        "threshold_percent": args.threshold_percent,
        "estimator": estimator,
        "baseline_token_by_file_top10": dict(sorted(baseline_by_file.items(), key=lambda item: item[1], reverse=True)[:10]),
        "preload_token_by_file": preload_by_file,
        "joiner_comparison": joined["comparison"],
        "metric_label": joined["metric_label"],
    }

    archive = Path(args.archive)
    archive.parent.mkdir(parents=True, exist_ok=True)
    with archive.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(summary, sort_keys=True) + "\n")
    report = Path(args.report)
    report.parent.mkdir(parents=True, exist_ok=True)
    report.write_text(_render(summary), encoding="utf-8")
    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    else:
        print(str(report))
    return 0 if status == "pass" else 1


if __name__ == "__main__":
    raise SystemExit(main())
