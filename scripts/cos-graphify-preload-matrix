def _git_paths(*, base: str | None, include_untracked: bool) -> list[str]:
    diff_args = ["git", "diff", "--name-only"]
    if base:
        diff_args.append(base)
    result = subprocess.run(diff_args, check=False, capture_output=True, text=True)
    if result.returncode != 0:
        raise SystemExit(result.stderr.strip() or "error: git diff failed")
    paths = [line.strip() for line in result.stdout.splitlines() if line.strip()]
    cached = subprocess.run(["git", "diff", "--cached", "--name-only"], check=False, capture_output=True, text=True)
    if cached.returncode != 0:
        raise SystemExit(cached.stderr.strip() or "error: git diff --cached failed")
    paths.extend(line.strip() for line in cached.stdout.splitlines() if line.strip())
    if include_untracked:
        untracked = subprocess.run(
            ["git", "ls-files", "--others", "--exclude-standard"],
            check=False,
            capture_output=True,
            text=True,
        )
        if untracked.returncode != 0:
            raise SystemExit(untracked.stderr.strip() or "error: git ls-files failed")
        paths.extend(line.strip() for line in untracked.stdout.splitlines() if line.strip())
    return _unique(paths)


def _matches(bundle: PreloadBundle, values: Iterable[str]) -> bool:
    normalized = [value.strip() for value in values if value.strip()]
    for value in normalized:
        for trigger in bundle.triggers:
            if value == trigger or value.startswith(trigger) or trigger in value:
                return True
    return False


def _unique(items: Iterable[str]) -> list[str]:
    seen: set[str] = set()
    out: list[str] = []
    for item in items:
        if item not in seen:
            seen.add(item)
            out.append(item)
    return out


def _render_markdown(bundles: list[PreloadBundle]) -> str:
    lines = ["# Graphify Preload Matrix Selection", ""]
    if not bundles:
        lines.extend(
            [
                "No Graphify-derived preload bundle matched the provided paths or symbols.",
                "Use ordinary source inspection or run `scripts/cos-graphify-hotspot-report` when graph context is needed.",
                "",
            ]
        )
        return "\n".join(lines)
    for bundle in bundles:
        lines.extend([f"## {bundle.label}", "", f"Key: `{bundle.key}`", "", bundle.rationale, "", "Preload files:", ""])
        lines.extend(f"- `{path}`" for path in bundle.preload_files)
        lines.extend(["", "Inspect paths:", ""])
        lines.extend(f"- `{path}`" for path in bundle.inspect_paths)
        lines.extend(["", "Confirmation tests:", ""])
        lines.extend(f"```bash\n{cmd}\n```" for cmd in bundle.tests)
        lines.append("")
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("items", nargs="*", help="Changed paths, symbols, or topic hints")
    parser.add_argument("--changed", action="store_true", help="Add changed Git paths from working tree and index")
    parser.add_argument("--base", help="Optional base revision for --changed, passed to git diff --name-only")
    parser.add_argument("--include-untracked", action="store_true", help="Include untracked Git paths when --changed is set")
    parser.add_argument("--all", action="store_true", help="Print every known bundle")
    parser.add_argument("--json", action="store_true", help="Emit JSON instead of Markdown")
    parser.add_argument("--out", help="Optional output file")
    args = parser.parse_args()

    items = list(args.items)
    if args.changed:
        items.extend(_git_paths(base=args.base, include_untracked=args.include_untracked))
    selected = list(BUNDLES) if args.all else [bundle for bundle in BUNDLES if _matches(bundle, items)]
    if args.json:
        payload = {
            "bundles": [asdict(bundle) for bundle in selected],
            "preload_files": _unique(path for bundle in selected for path in bundle.preload_files),
            "inspect_paths": _unique(path for bundle in selected for path in bundle.inspect_paths),
            "tests": _unique(command for bundle in selected for command in bundle.tests),
        }
        output = json.dumps(payload, indent=2, sort_keys=True) + "\n"
    else:
        output = _render_markdown(selected)
    if args.out:
        out = Path(args.out)
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(output, encoding="utf-8")
        print(f"COS_GRAPHIFY_PRELOAD_MATRIX={out}")
    else:
        print(output, end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
