#!/usr/bin/env python3
# SCOPE: os-only
"""Run a deterministic controlled Graphify token-reduction smoke test.

This smoke does not call a model. It creates paired Claude Code JSONL fixtures for
one controlled task and verifies that the Graphify run-telemetry joiner can measure
an expected real-token reduction under identical task/model/tool/cache controls.
"""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
JOINER = ROOT / "scripts" / "cos-graphify-run-telemetry"
DEFAULT_ARCHIVE = ROOT / ".cognitive-os" / "metrics" / "graphify-token-reduction-smoke.jsonl"
DEFAULT_REPORT = ROOT / ".cognitive-os" / "reports" / "graphify-token-reduction-smoke-report.md"

CONTROL = {
    "task_id": "graphify-controlled-context-selection-smoke",
    "task": "Inspect the harness event contract and identify confirmation tests.",
    "model": "claude-sonnet-smoke",
    "tool_policy": "read-only-source-inspection",
    "prompt_policy": "same task text and same system preamble fixture",
    "cache_policy": "same cache creation/read fixture values",
    "baseline_condition": "broad-slice-context",
    "graphify_condition": "graphify-preload-bundle",
}


def _session_row(*, timestamp: str, input_tokens: int, output_tokens: int, cache_creation: int, cache_read: int) -> dict[str, Any]:
    return {
        "type": "assistant",
        "timestamp": timestamp,
        "message": {
            "role": "assistant",
            "model": CONTROL["model"],
            "usage": {
                "input_tokens": input_tokens,
                "output_tokens": output_tokens,
                "cache_creation_input_tokens": cache_creation,
                "cache_read_input_tokens": cache_read,
            },
            "content": [
                {
                    "type": "tool_use",
                    "id": "toolu_smoke_read_base",
                    "name": "Read",
                    "input": {"file_path": "lib/harness_adapter/base.py"},
                }
            ],
        },
    }


def _write_session(path: Path, *, input_tokens: int, output_tokens: int) -> None:
    rows = [
        _session_row(
            timestamp="2026-05-22T10:00:00Z",
            input_tokens=input_tokens,
            output_tokens=output_tokens,
            cache_creation=100,
            cache_read=500,
        ),
        {
            "type": "progress",
            "timestamp": "2026-05-22T10:02:00Z",
            "data": {"type": "agent_progress", "agentId": "agent-smoke", "message": "controlled smoke complete"},
        },
    ]
    path.write_text("\n".join(json.dumps(row) for row in rows) + "\n", encoding="utf-8")


def _write_matrix(path: Path) -> None:
    path.write_text(
        json.dumps(
            {
                "bundles": [
                    {
                        "key": "harness-events",
                        "label": "Harness event contract",
                        "rationale": "Controlled smoke exercises Graphify preload bundle selection for harness event work.",
                    }
                ],
                "preload_files": [
                    "lib/harness_adapter/base.py",
                    "lib/harness_adapter/codex.py",
                    "lib/sprint_orchestrator.py",
                ],
                "inspect_paths": ["lib/harness_adapter/base.py", "lib/sprint_orchestrator.py"],
                "tests": [".venv/bin/python -m pytest tests/unit/test_harness_adapter_base.py -q"],
            },
            indent=2,
            sort_keys=True,
        )
        + "\n",
        encoding="utf-8",
    )


def _run_joiner(*, baseline: Path, current: Path, matrix: Path) -> dict[str, Any]:
    completed = subprocess.run(
        [
            str(JOINER),
            "--session",
            str(current),
            "--baseline-session",
            str(baseline),
            "--matrix-json",
            str(matrix),
            "--json",
        ],
        cwd=ROOT,
        check=False,
        capture_output=True,
        text=True,
    )
    if completed.returncode != 0:
        raise SystemExit(completed.stderr.strip() or completed.stdout.strip() or "graphify run telemetry joiner failed")
    return json.loads(completed.stdout)


def _summarize(payload: dict[str, Any], *, threshold_percent: float) -> dict[str, Any]:
    comparison = payload["comparison"]
    baseline_total = int(comparison["baseline_total_tokens"])
    current_total = int(comparison["current_total_tokens"])
    delta = baseline_total - current_total
    reduction_percent = round((delta / baseline_total) * 100, 2) if baseline_total else 0.0
    controls_match = (
        payload["session_metrics"].get("models_used") == payload["baseline_session_metrics"].get("models_used")
        and payload["session_metrics"].get("cache_creation_tokens") == payload["baseline_session_metrics"].get("cache_creation_tokens")
        and payload["session_metrics"].get("cache_read_tokens") == payload["baseline_session_metrics"].get("cache_read_tokens")
    )
    status = "pass" if controls_match and reduction_percent >= threshold_percent else "fail"
    return {
        "status": status,
        "threshold_percent": threshold_percent,
        "reduction_percent": reduction_percent,
        "baseline_total_tokens": baseline_total,
        "graphify_total_tokens": current_total,
        "saved_tokens": delta,
        "controls_match": controls_match,
        "control": CONTROL,
        "joiner_metric_label": payload["metric_label"],
        "preload_estimated_tokens": payload["preload_estimate"]["estimated_tokens"],
        "joiner_comparison": comparison,
    }


def _append_archive(path: Path, summary: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    row = {"timestamp": datetime.now(timezone.utc).isoformat(), "source": "graphify-token-reduction-smoke", **summary}
    with path.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(row, sort_keys=True) + "\n")


def _render_report(summary: dict[str, Any]) -> str:
    return "\n".join(
        [
            "# Graphify Controlled Token Reduction Smoke Report",
            "",
            "This deterministic smoke uses synthetic Claude Code JSONL sessions to prove the measurement path for controlled baseline/current token reduction. It does not call a model and does not claim live production savings.",
            "",
            "## Result",
            "",
            f"Status: `{summary['status']}`",
            f"Threshold: {summary['threshold_percent']}%",
            f"Measured reduction: {summary['reduction_percent']}%",
            f"Baseline total tokens: {summary['baseline_total_tokens']}",
            f"Graphify-preload total tokens: {summary['graphify_total_tokens']}",
            f"Saved tokens: {summary['saved_tokens']}",
            f"Controls match: `{summary['controls_match']}`",
            f"Joiner metric label: `{summary['joiner_metric_label']}`",
            f"Preload estimated tokens: {summary['preload_estimated_tokens']}",
            "",
            "## Controlled Conditions",
            "",
            f"Task: {CONTROL['task']}",
            f"Model: `{CONTROL['model']}`",
            f"Tool policy: `{CONTROL['tool_policy']}`",
            f"Prompt policy: `{CONTROL['prompt_policy']}`",
            f"Cache policy: `{CONTROL['cache_policy']}`",
            "",
            "## Evidence vs Inference",
            "",
            "Evidence:",
            "",
            "- The smoke generated paired JSONL sessions with matching task/model/tool/cache controls.",
            "- `scripts/cos-graphify-run-telemetry` measured the paired token delta from those sessions.",
            "",
            "Inference boundary:",
            "",
            "- This proves the controlled measurement harness, not live model behavior. Live causal savings still require running equivalent real agent tasks.",
            "",
        ]
    )


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--archive", default=str(DEFAULT_ARCHIVE))
    parser.add_argument("--report", default=str(DEFAULT_REPORT))
    parser.add_argument("--threshold-percent", type=float, default=20.0)
    parser.add_argument("--baseline-input-tokens", type=int, default=12000)
    parser.add_argument("--graphify-input-tokens", type=int, default=4800)
    parser.add_argument("--output-tokens", type=int, default=800)
    parser.add_argument("--reset", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    archive = Path(args.archive)
    report = Path(args.report)
    if args.reset and archive.exists():
        archive.unlink()

    with tempfile.TemporaryDirectory(prefix="cos-graphify-token-smoke-") as raw_tmp:
        tmp = Path(raw_tmp)
        baseline = tmp / "baseline.jsonl"
        current = tmp / "graphify.jsonl"
        matrix = tmp / "matrix.json"
        _write_session(baseline, input_tokens=args.baseline_input_tokens, output_tokens=args.output_tokens)
        _write_session(current, input_tokens=args.graphify_input_tokens, output_tokens=args.output_tokens)
        _write_matrix(matrix)
        payload = _run_joiner(baseline=baseline, current=current, matrix=matrix)

    summary = _summarize(payload, threshold_percent=args.threshold_percent)
    _append_archive(archive, summary)
    report.parent.mkdir(parents=True, exist_ok=True)
    report.write_text(_render_report(summary), encoding="utf-8")
    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    else:
        print(str(report))
    return 0 if summary["status"] == "pass" else 1


if __name__ == "__main__":
    raise SystemExit(main())
