#!/usr/bin/env python3
# SCOPE: os-only
"""Inspect the declarative Cognitive OS harness hook projection policy."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
POLICY = ROOT / "manifests" / "harness-hook-projection-policy.yaml"


def load_policy(path: Path = POLICY) -> dict[str, Any]:
    return yaml.safe_load(path.read_text(encoding="utf-8"))


def profile_hooks(policy: dict[str, Any], harness: str, profile: str) -> list[dict[str, Any]]:
    profiles = policy["harnesses"][harness]["profiles"]
    seen: set[str] = set()
    current = profile
    while True:
        if current in seen:
            raise SystemExit(f"profile alias cycle for {harness}/{profile}")
        seen.add(current)
        spec = profiles[current]
        alias = spec.get("alias_of")
        if not alias:
            return list(spec.get("hooks", []))
        current = str(alias)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--harness", default="claude-code")
    parser.add_argument("--profile", default="default")
    parser.add_argument("--event", default="PreToolUse")
    parser.add_argument("--matcher", default="Bash")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    policy = load_policy()
    hooks = [h for h in profile_hooks(policy, args.harness, args.profile) if h.get("event") == args.event and h.get("matcher") == args.matcher]
    scripts = [script for h in hooks for script in h.get("scripts", [])]
    payload = {"harness": args.harness, "profile": args.profile, "event": args.event, "matcher": args.matcher, "scripts": scripts}
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        for script in scripts:
            print(script)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
