#!/usr/bin/env python3
# SCOPE: both
"""Execute one provider call out-of-process for ADR-232 provider isolation."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))


def _emit(payload: dict) -> int:
    print(json.dumps(payload, sort_keys=True))
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--provider", required=True)
    parser.add_argument("--claude-model")
    args = parser.parse_args(argv)
    prompt = sys.stdin.read()
    if args.provider == "echo":
        return _emit({"success": True, "text": prompt, "tokens_in": len(prompt.split()), "tokens_out": 0, "cost_usd": 0.0, "error": "", "model": "echo", "provider_label": "echo"})
    if args.provider == "qwen":
        from lib.dispatch import _try_qwen
        result = _try_qwen(prompt, claude_model=args.claude_model)
    else:
        from lib.dispatch import _try_registry_provider
        result = _try_registry_provider(args.provider, prompt, claude_model=args.claude_model)
    if result is None:
        return _emit({"success": False, "text": "", "tokens_in": 0, "tokens_out": 0, "cost_usd": 0.0, "error": "provider unavailable", "model": "", "provider_label": args.provider})
    return _emit(result)


if __name__ == "__main__":
    raise SystemExit(main())
