#!/usr/bin/env python3
# SCOPE: both
"""CLI wrapper for lib.wiki_ingester."""
from __future__ import annotations

import argparse
import json
from pathlib import Path

from lib.wiki_ingester import WikiIngester


def main() -> int:
    parser = argparse.ArgumentParser(description="Ingest a raw source into the Cognitive OS docs vault.")
    parser.add_argument("--project-dir", default=".", help="Project root; defaults to cwd.")
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--url", help="URL to ingest.")
    group.add_argument("--file", help="Local file path to ingest.")
    group.add_argument("--text", help="Inline text to ingest.")
    parser.add_argument("--title", required=True, help="Title for file/text ingests or URL override.")
    parser.add_argument("--json", action="store_true", help="Emit JSON result.")
    args = parser.parse_args()

    ingester = WikiIngester(Path(args.project_dir).resolve())
    if args.url:
        result = ingester.ingest_url(args.url, title=args.title)
    elif args.file:
        result = ingester.ingest_file(Path(args.file), title=args.title)
    else:
        result = ingester.ingest_text(args.title, args.text or "")

    payload = {
        "source_id": result.source_id,
        "page_path": str(result.page_path),
        "claim_id": result.claim_id,
        "redacted_secrets_count": result.redacted_secrets_count,
        "already_existed": result.already_existed,
    }
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"wiki-ingest: {payload['source_id']} -> {payload['page_path']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
