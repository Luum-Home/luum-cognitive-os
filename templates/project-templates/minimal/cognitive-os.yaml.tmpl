# Cognitive OS Configuration — generated by cos new
project:
  name: {{.ProjectName}}
  phase: {{.Phase}}

sessions:
  concurrency: true
  isolation: per-session
  lock_strategy: advisory
  lock_timeout_seconds: 300
  cleanup_on_exit: true

models:
  routing:
    default: sonnet
    design: opus
    implementation: sonnet
    debugging: opus
    documentation: haiku

quality:
  auto_verify: true
  verification_retries: 3

resources:
  budget:
    monthly_limit_usd: 200
    daily_alert_usd: 10
    per_agent_max_usd: 2.00

model_capability:
  level: 3

efficiency:
  profile: {{.Profile}}
